 #ifndef CIEEngine_h
@@ -11,12 +12,24 @@
 #include <stdio.h>
 #include <openssl/crypto.h>
 #include <openssl/objects.h>
-#include <openssl/engine.h>
+#include <openssl/opensslv.h>
 
