From 8e3085767c6066231a44f3f058fbd32cf7a21bc0 Mon Sep 17 00:00:00 2001
From: Luca Magrone <luca@magrone.cc>
Date: Sun, 28 Jun 2026 01:22:11 +0200
Subject: [PATCH] Implement OpenSSL provider

Support newer OpenSSL provider API if the detected version is at least
3.0.0, fall back to the legacy code for older versions.

Signed-off-by: Luca Magrone <luca@magrone.cc>
---
 cie-pkcs11/Sign/CIEEngine.h        |  19 +-
 cie_sign_sdk/include/CIEEngine.h   |  19 +-
 cie_sign_sdk/include/CIEProvider.h |  99 +++++
 cie_sign_sdk/src/CIEEngine.c       |  38 ++
 cie_sign_sdk/src/CIEProvider.c     | 659 +++++++++++++++++++++++++++++
 5 files changed, 828 insertions(+), 6 deletions(-)
 create mode 100644 cie_sign_sdk/include/CIEProvider.h
 create mode 100644 cie_sign_sdk/src/CIEProvider.c

diff --git a/cie-pkcs11/Sign/CIEEngine.h b/cie-pkcs11/Sign/CIEEngine.h
index 15af145..0fe86bb 100644
--- a/cie-pkcs11/Sign/CIEEngine.h
+++ b/cie-pkcs11/Sign/CIEEngine.h
@@ -3,6 +3,7 @@
 //  CIESDK
 //
 //  Created by ugo chirico on 26.02.2020.
+//  Updated for OpenSSL 3.x Provider support.
 //
 
 #ifndef CIEEngine_h
@@ -11,12 +12,24 @@
 #include <stdio.h>
 #include <openssl/crypto.h>
 #include <openssl/objects.h>
-#include <openssl/engine.h>
+#include <openssl/opensslv.h>
 
-typedef short (*sign)(unsigned char* tosign, size_t len, unsigned char* signature, size_t* psiglen);
+#if OPENSSL_VERSION_NUMBER >= 0x30000000
+# include <openssl/provider.h>
+# include <openssl/evp.h>
+# include "CIEProvider.h"
+#else
+# include <openssl/engine.h>
+#endif
 
+typedef short (*sign)(unsigned char* tosign, size_t len, unsigned char* signature, size_t* psiglen);
 
+#if OPENSSL_VERSION_NUMBER >= 0x30000000
+/* Provider-based API (OpenSSL >= 3.0) */
+void engine_load_cie(sign sign_cb);  /* compatibility wrapper → provider_load_cie */
+#else
+/* Legacy engine-based API (OpenSSL < 3.0) */
 void engine_load_cie(sign sign_cb);
-
+#endif
 
 #endif /* CIEEngine_h */
